# ── App ──────────────────────────────────────────────
APP_NAME=MNIST ANN Classifier
APP_VERSION=1.0.0
DEBUG=false

# ── Model ────────────────────────────────────────────
MODEL_PATH=../model/model.h5
INPUT_SHAPE=784          # 28×28 flattened

# ── API ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:8501,http://frontend:8501

# ── Frontend ─────────────────────────────────────────
API_BASE_URL=http://localhost:8000
